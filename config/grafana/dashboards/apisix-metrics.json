{
  "title": "APISIX — Gateway Metrics",
  "uid": "apisix-metrics",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["apisix", "gateway"],
  "panels": [
    {
      "id": 1,
      "title": "Requests per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "sum(rate(apisix_http_status[$__rate_interval])) by (code)",
        "legendFormat": "HTTP {{code}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "title": "Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(apisix_http_latency_bucket{type=\"request\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(apisix_http_latency_bucket{type=\"request\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(apisix_http_latency_bucket{type=\"request\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99", "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 3,
      "title": "WAF Block Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "sum(rate(apisix_http_status{code=\"403\"}[$__rate_interval])) / sum(rate(apisix_http_status[$__rate_interval])) * 100",
        "legendFormat": "Block %", "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 4,
      "title": "Bandwidth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "sum(rate(apisix_bandwidth[$__rate_interval])) by (type)",
        "legendFormat": "{{type}}", "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 5,
      "title": "etcd Reachable",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "sum(apisix_etcd_reachable)",
        "instant": true, "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 6,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "sum(apisix_nginx_http_current_connections{state=\"active\"})",
        "instant": true, "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
